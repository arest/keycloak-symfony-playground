{% extends 'base.html.twig' %}

{% block title %}Home{% endblock %}

{% block body %}
    <h1>Keycloak SSO Playground</h1>
    <p>Welcome to the Symfony BFF (Backend-for-Frontend) demo.</p>
    <p>
        {% if token_storage.isAuthenticated %}
            You are logged in. <a href="{{ path('dashboard') }}">Go to Dashboard</a>
        {% else %}
            <a href="{{ path('login') }}">Login with Keycloak</a>
        {% endif %}
    </p>
{% endblock %}
